[
  {
    "label": "lazygit",
    "command": "lazygit -p $ZED_WORKTREE_ROOT",
    "hide": "on_success",
    "shell": {
      "program": "sh"
    }
  },
  {
    "label": "fzf_file",
    "command": "zed $(fzf --preview 'bat --color=always {}' --preview-window '~3')",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  }
]
