{
    "$schema": "https://opencode.ai/config.json",
    "autoshare": false,
    "autoupdate": true,
    "instructions": [
        "common_rules/*.md",
        "AGENTS.local.md"
    ],
    "permission": {
        "*": "allow",
        "external_directory" : {
            "*": "ask",
            "~/.agents/**": "allow",
            "~/github/**": "allow",
            "~/.plannotator/**": "allow",
            "~/Library/Application Support/rtk/**": "allow",
        },
        "bash": {
            "rm -rf": "ask",
            "git push * --force *": "ask",
            "git push * -f *": "ask",
            "git reset * -h *": "ask",
            "git reset * --hard *": "ask",
        },
    },
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
        "@mohak34/opencode-notifier@latest",
        "opencode-betterglob",
        "opencode-bettergrep",
        "opencode-betterread",
        ["@plannotator/opencode@latest",{
            "workflow": "user-managed"}]
    ],
    "provider": {
        "openai": {
            "models": {
                "gpt-5.5": {
                    "name": "GPT-5.5 (Codex)",
                    "family": "gpt",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                },
                "gpt-5.5-fast": {
                    "id": "gpt-5.5",
                    "name": "GPT-5.5 Fast (Codex)",
                    "family": "gpt",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "options": {
                        "serviceTier": "priority"
                    },
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                },
                "gpt-5.5-pro": {
                    "name": "GPT-5.5 Pro (Codex)",
                    "family": "gpt-pro",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                }
            }
        },
        "prism": {
    "compaction": {
        "auto": false,
    },
    "experimental": {
        "batch_tool": true,
    },
    "lsp": {
        "pyright": {
            "disabled": true
        },
        "ty": {
            "command": ["uvx", "ty", "server"],
            "extensions": [".py", ".pyi"]
        },
        "jdtls": {
            "command": [
                "jdtls",
                "--jvm-arg=-Xmx16G",
                "--jvm-arg=-Xms1G",
                "--jvm-arg=-XX:+UseParallelGC",
                "--jvm-arg=-XX:+UseStringDeduplication",
                "--jvm-arg=-Dsun.zip.disableMemoryMapping",
                "--jvm-arg=-XX:GCTimeRatio=4",
                "--jvm-arg=-XX:AdaptiveSizePolicyWeight=90"
            ],
            "extensions": [".java"],
            "initialization": {
                "settings": {
                    "java": {
                        "jdt": {
                            "ls": {
                                "lombokSupport": {
                                    "enabled": true
                                }
                            }
                        },
                        "compile": {
                            "nullAnalysis": {
                                "mode": "automatic"
                            }
                        },
                        "referencesCodeLens": {
                            "enabled": false
                        },
                        "implementationsCodeLens": {
                            "enabled": false
                        },
                        "signatureHelp": {
                            "enabled": true
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": true
        },
        "datadog": {
            "type": "remote",
            "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true
        },
        "deepwiki": {
            "type": "remote",
            "url": "https://mcp.deepwiki.com/mcp",
            "enabled": true
        },
            "type": "local",
            "command": [
                "uvx",
            ],
    }
}
