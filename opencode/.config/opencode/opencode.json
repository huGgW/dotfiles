{
    "$schema": "https://opencode.ai/config.json",
    "autoshare": false,
    "autoupdate": true,
    "instructions": ["common_rules/*.md"],
    "permission": {
        "*": "allow",
        "external_directory" : {
            "*": "ask",
            "~/github/**": "allow"
        },
        "bash": {
            "rm -rf": "ask",
        },
    },
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
        "@mohak34/opencode-notifier@latest",
        ["opencode-auto-resume", {
            "chunkTimeoutMs": 600000,
            "gracePeriodMs": 8000,
            "checkIntervalMs": 10000,
            "maxRetries": 3,
            "baseBackoffMs": 60000,
            "maxBackoffMs": 480000,
            "subagentWaitMs": 600000,
            "loopMaxContinues": 3,
            "loopWindowMs": 1800000
        }],
    ],
    "provider": {
        "openai": {
            "models": {
                "gpt-5.5": {
                    "name": "GPT-5.5 (Codex)",
                    "family": "gpt",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                },
                "gpt-5.5-fast": {
                    "id": "gpt-5.5",
                    "name": "GPT-5.5 Fast (Codex)",
                    "family": "gpt",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "options": {
                        "serviceTier": "priority"
                    },
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                },
                "gpt-5.5-pro": {
                    "name": "GPT-5.5 Pro (Codex)",
                    "family": "gpt-pro",
                    "release_date": "2026-04-23",
                    "attachment": true,
                    "reasoning": true,
                    "temperature": false,
                    "tool_call": true,
                    "limit": {
                        "context": 272000,
                        "input": 272000,
                        "output": 128000
                    },
                    "modalities": {
                        "input": ["text", "image", "pdf"],
                        "output": ["text"]
                    }
                }
            }
        },
        "prism": {
    "compaction": {
        "auto": false,
    },
    "experimental": {
        "batch_tool": true,
    },
    "lsp": {
        "pyright": {
            "disabled": true
        },
        "ty": {
            "command": ["uvx", "ty", "server"],
            "extensions": [".py", ".pyi"]
        },
        "jdtls": {
            "command": [
                "jdtls",
                "--jvm-arg=-Xmx16G",
                "--jvm-arg=-Xms1G",
                "--jvm-arg=-XX:+UseParallelGC",
                "--jvm-arg=-XX:+UseStringDeduplication",
                "--jvm-arg=-Dsun.zip.disableMemoryMapping",
                "--jvm-arg=-XX:GCTimeRatio=4",
                "--jvm-arg=-XX:AdaptiveSizePolicyWeight=90"
            ],
            "extensions": [".java"],
            "initialization": {
                "settings": {
                    "java": {
                        "jdt": {
                            "ls": {
                                "lombokSupport": {
                                    "enabled": true
                                }
                            }
                        },
                        "compile": {
                            "nullAnalysis": {
                                "mode": "automatic"
                            }
                        },
                        "referencesCodeLens": {
                            "enabled": false
                        },
                        "implementationsCodeLens": {
                            "enabled": false
                        },
                        "signatureHelp": {
                            "enabled": true
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "datadog": {
            "type": "remote",
            "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "notionMCP": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "markitdown": {
            "type": "local",
            "command": ["uvx", "markitdown-mcp"],
            "enabled": false
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--no-performance-crud",
                "--no-usage-statistics",
                "--autoConnect"
            ],
            "enabled": false
        },
        "context7": {
            "type": "local",
            "command": ["npx", "-y", "@upstash/context7-mcp"],
            "enabled": true
        },
        "grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true
        },
        "deepwiki": {
            "type": "remote",
            "url": "https://mcp.deepwiki.com/mcp",
            "enabled": true
        },
        "ast-grep": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/ast-grep/ast-grep-mcp",
                "ast-grep-server"
            ],
            "enabled": true
        }
    }
}
