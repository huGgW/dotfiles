{
    "$schema": "https://opencode.ai/config.json",
    "autoshare": false,
    "autoupdate": true,
    "instructions": ["common_rules/*.md"],
    "permission": {
        "webfetch": "allow",
        "skill": "allow",
        "doom_loop": "deny",
        "lsp": "allow",
        "bash": {
            "*": "ask",
            "pwd": "allow",
            "ls": "allow",
            "ls *": "allow",
            "echo": "allow",
            "echo *": "allow",
            "cat": "allow",
            "cat *": "allow",
            "date": "allow",
            "date *": "allow",
            "head": "allow",
            "head *": "allow",
            "tail": "allow",
            "tail *": "allow",
            "diff": "allow",
            "diff *": "allow",
            "printf": "allow",
            "printf *": "allow",
            "fd": "allow",
            "fd *": "allow",
            "find": "allow",
            "find *": "allow",
            "rg": "allow",
            "rg *": "allow",
            "grep": "allow",
            "grep *": "allow",
            "sed": "allow",
            "sed *": "allow",
            "sort": "allow",
            "sort *": "allow",
            "wc": "allow",
            "wc *": "allow",
            "tr": "allow",
            "tr *": "allow",
            "cut": "allow",
            "cut *": "allow",
            "uniq": "allow",
            "uniq *": "allow",
            "awk": "allow",
            "awk *": "allow",
            "which": "allow",
            "which *": "allow",
            "file": "allow",
            "file *": "allow",
            "tree": "allow",
            "tree *": "allow",
            "jq": "allow",
            "jq *": "allow",
            "basename": "allow",
            "basename *": "allow",
            "dirname": "allow",
            "dirname *": "allow",
            "realpath": "allow",
            "realpath *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git status": "allow",
            "git status *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "gh pr list": "allow",
            "gh pr list *": "allow",
            "gh pr view": "allow",
            "gh pr view *": "allow",
            "gh pr diff": "allow",
            "gh pr diff *": "allow",
            "./gradlew tasks": "allow",
            "./gradlew tasks *": "allow",
            "git branch": "allow",
            "git branch *": "allow",
            "git show": "allow",
            "git show *": "allow",
            "git tag": "allow",
            "git tag *": "allow",
            "git stash list": "allow",
            "git stash list *": "allow",
            "git remote": "allow",
            "git remote *": "allow",
            "git rev-parse": "allow",
            "git rev-parse *": "allow",
            "gh issue list": "allow",
            "gh issue list *": "allow",
            "gh issue view": "allow",
            "gh issue view *": "allow",
            "gh repo view": "allow",
            "gh repo view *": "allow"
        }
    },
    "agent": {
        "build": {
            "permission": {
                "edit": "allow",
                "doom_loop": "ask",
                "bash": {
                    "mkdir": "allow",
                    "mkdir *": "allow",
                    "go build": "allow",
                    "go build *": "allow",
                    "go test": "allow",
                    "go test *": "allow",
                    "make build": "allow",
                    "make build *": "allow",
                    "make test": "allow",
                    "make test *": "allow",
                    "./gradlew build": "allow",
                    "./gradlew build *": "allow",
                    "./gradlew test": "allow",
                    "./gradlew test *": "allow",
                    "git add": "allow",
                    "git add *": "allow",
                    "git commit": "allow",
                    "git commit *": "allow"
                }
            }
        }
    },
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
        "@franlol/opencode-md-table-formatter@0.0.3",
        "@mohak34/opencode-notifier@latest"
    ],
    "provider": {
        "openai": {
            "options": {
                "reasoningEffort": "medium",
                "reasoningSummary": "auto",
                "textVerbosity": "medium",
                "include": ["reasoning.encrypted_content"],
                "store": false
            }
        }
    },
    "lsp": {
        "pyright": {
            "disabled": true
        },
        "ty": {
            "command": ["uvx", "ty", "server"],
            "extensions": [".py", ".pyi"]
        },
        "jdtls": {
            "command": [
                "jdtls",
                "--jvm-arg=-Xmx16G",
                "--jvm-arg=-Xms1G",
                "--jvm-arg=-XX:+UseParallelGC",
                "--jvm-arg=-XX:+UseStringDeduplication",
                "--jvm-arg=-Dsun.zip.disableMemoryMapping",
                "--jvm-arg=-XX:GCTimeRatio=4",
                "--jvm-arg=-XX:AdaptiveSizePolicyWeight=90"
            ],
            "extensions": [".java"],
            "initialization": {
                "settings": {
                    "java": {
                        "jdt": {
                            "ls": {
                                "lombokSupport": {
                                    "enabled": true
                                }
                            }
                        },
                        "compile": {
                            "nullAnalysis": {
                                "mode": "automatic"
                            }
                        },
                        "referencesCodeLens": {
                            "enabled": false
                        },
                        "implementationsCodeLens": {
                            "enabled": false
                        },
                        "signatureHelp": {
                            "enabled": true
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "sentry": {
            "type": "remote",
            "url": "https://mcp.sentry.dev/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "notionMCP": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp",
            "oauth": {
                "scope": "tools:read"
            },
            "enabled": false
        },
        "markitdown": {
            "type": "local",
            "command": ["uvx", "markitdown-mcp"],
            "enabled": false
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--no-performance-crud",
                "--no-usage-statistics"
            ],
            "enabled": false
        },
        "context7": {
            "type": "local",
            "command": ["npx", "-y", "@upstash/context7-mcp"],
            "enabled": true
        },
        "grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true
        },
        "deepwiki": {
            "type": "remote",
            "url": "https://mcp.deepwiki.com/mcp",
            "enabled": true
        },
        "ast-grep": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/ast-grep/ast-grep-mcp",
                "ast-grep-server"
            ],
            "enabled": true
        }
    }
}
