    "plugin_id": "smart-workspace",
    "name": "Smart Workspace",
    "version": "0.1.0",
    "min_herdr_version": "0.7.0",
    "description": "Switch Herdr workspaces with fzf and zoxide.",
    "manifest_path": "/Users/logan/.config/herdr/plugins/github/smart-workspace-f6b92f176fec/herdr-plugin.toml",
    "plugin_root": "/Users/logan/.config/herdr/plugins/github/smart-workspace-f6b92f176fec",
    "enabled": true,
    "platforms": [
      "linux",
      "macos"
    ],
    "actions": [
      {
        "id": "switch",
        "title": "Switch workspace",
        "contexts": [
          "workspace"
        ],
        "command": [
          "python3",
          "-m",
          "smart_workspace.open_pane"
        ]
      },
      {
        "id": "switch-previous",
        "title": "Switch to previous workspace",
        "contexts": [
          "workspace"
        ],
        "command": [
          "python3",
          "-m",
          "smart_workspace.previous"
        ]
      }
    ],
    "events": [
      {
        "on": "workspace.focused",
        "command": [
          "python3",
          "-m",
          "smart_workspace.track"
        ]
      }
    ],
    "panes": [
      {
        "id": "picker",
        "title": "Smart Workspace",
        "placement": "overlay",
        "command": [
          "python3",
          "-m",
          "smart_workspace.picker"
        ]
      }
    ],
